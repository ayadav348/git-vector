# =======================================================================
# 📦 Dependency Moat
# =======================================================================
# Never commit the massive node_modules directory to the codebase index
node_modules/
jspm_packages/

# =======================================================================
# ⚙️ Local Configuration & State Persistence (CRITICAL)
# =======================================================================
# Bypasses local environment setups, API tokens, and hardcoded folder configs
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# If you decide to add testing config scripts or mock persistent databases locally
config.local.json
.config/

# =======================================================================
# 🚀 Build Matrices & Execution Logs
# =======================================================================
# Logs generated by running npm start or debugger pipelines
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Diagnostic performance traces or core execution dumps
.eslintcache
.stylelintcache
.rpt2_cache/
.rts2_cache_cjs/
.rts2_cache_es/
.tsbuildinfo

# =======================================================================
# 💻 Operating System Artifacts (Arch/KDE/Windows)
# =======================================================================
# Prevent standard kernel/file-manager cache tracking leaks
.DS_Store
Thumbs.db
desktop.ini
*.swp
*~
.fuse_hidden*
.directory
